def nca_log(module, action, detail):
    """Standard NCA terminal log layout for trade verification."""
    timestamp = time.strftime('%H:%M:%S')
    print(f"[{timestamp}] NCA // {module.upper()} // ACT: {action.upper()} // DET: {detail}")

# ==============================================================================
# DAY 8 PREDICTIVE LOOK-AHEAD CORE ALGORITHM
# ==============================================================================
@app.route('/api/predictive/look_ahead', methods=['GET'])
def run_look_ahead():
    """
    Simulates N.E.L.S.O.N.'s predictive daemon. It looks 15 minutes into the 
    future based on the custom day/time passed in the URL parameters.
    Example: /api/predictive/look_ahead?day=Mon&time=07:05
    """
    test_day = request.args.get('day', time.strftime('%a'))
    time_str = request.args.get('time', time.strftime('%H:%M'))
    
    try:
        current_dt = datetime.strptime(time_str, "%H:%M")
    except ValueError:
        return jsonify({"error": "Invalid time format. Use HH:MM"}), 400

    nca_log("CORE", "RUN_LOOK_AHEAD", f"Scanning ledger pattern clusters for {test_day} around {time_str}...")
    
    predictions_triggered = []

    # Parse historical database for events happening within a 15-minute window
    for event in historical_habit_ledger:
        event_dt = datetime.strptime(event["time"], "%H:%M")
        time_difference = event_dt - current_dt
        
        # Check if historical event falls within a 0 to +15 minute window from 'now'
        if 0 <= time_difference.total_seconds() <= 900:
            # Check for generic weekday clustering (Mon-Fri)
            is_weekday_match = test_day in ["Mon", "Tue", "Wed", "Thu", "Fri"] and event["day"] in ["Mon", "Tue", "Wed", "Thu", "Fri"]
            
            if event["day"] == test_day or is_weekday_match:
                detail_msg = f"Predicted manual use of [{event['device']}] -> Executing automation pre-heat/run sequence."
                nca_log("PREDICTIVE", "AUTO_PASSIVE_ENGAGE", detail_msg)
                predictions_triggered.append(event)

    return jsonify({
        "simulated_time": time_str,
        "simulated_day": test_day,
        "look_ahead_window_minutes": 15,
        "actions_preempted": predictions_triggered,
        "count": len(predictions_triggered)
    })


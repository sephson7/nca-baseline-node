@app.route('/api/manual/interact', methods=['GET'])
def manual_interaction():
    """
    Logs a live manual event from the user to the runtime terminal screen.
    Example: /api/manual/interact?device=keurig&action=BREW_START
    """
    device = request.args.get('device', 'unknown')
    action = request.args.get('action', 'TRIGGER')
    
    nca_log("MANUAL_AUDIT", "USER_PROMPT", f"User manually executed {action} on {device}. Logging timestamp to memory.")
    return jsonify({"status": "LOGGED", "device": device, "action": action})

